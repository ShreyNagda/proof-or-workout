# ─────────────────────────────────────────────────────────────
# Proof of Workout — Environment Variables
# Copy this file to .env.local and fill in real values.
# ─────────────────────────────────────────────────────────────

# ── Client-side (prefixed NEXT_PUBLIC_) ──────────────────────

# Sepolia RPC URL (Alchemy / Infura recommended)
# Example Alchemy: https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Deployed contract address on Sepolia
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourContractAddressHere

# ── Server-side only (NEVER prefix with NEXT_PUBLIC_) ────────

# Relayer private key — used server-side to sign submitProof()
# IMPORTANT: Never expose this in the browser. Use a dedicated
# burner wallet funded with Sepolia ETH for gas.
RELAYER_PRIVATE_KEY=0xYourRelayerPrivateKeyHere

# Server-side RPC (can be same as public or a private endpoint)
SEPOLIA_RPC_URL=https://rpc.sepolia.org
